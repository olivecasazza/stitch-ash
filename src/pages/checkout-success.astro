---
// /checkout-success?sku=stitch
// Standalone, framework-free confirmation page.
//
// IMPORTANT: This is an Astro static build (`output: 'static'`), so the
// frontmatter runs at BUILD time, not per-request. We cannot read
// `Astro.url.searchParams` for the user's sku at SSG. Instead, the page
// ships a tiny inline script that resolves `?sku=` against a known SKU
// map on the client and swaps in the product name + image.
//
// This page is intentionally minimal — the winning design draft will likely
// replace it. But it must work on `main` post-merge in case backend ships
// first.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <title>Reservation · STITCH AND ASH</title>
    <link rel="stylesheet" href="/styles/global.css" />
    <style>
      .confirm {
        max-width: 36rem;
        margin: 6rem auto;
        padding: 0 1.5rem;
        text-align: center;
        color: var(--bone, #EFE6D2);
      }
      .confirm h1 {
        font-size: clamp(2rem, 6vw, 3.5rem);
        letter-spacing: 0.02em;
        margin: 0 0 1.5rem;
      }
      .confirm .ember {
        color: var(--ember, #A8221A);
      }
      .confirm figure {
        margin: 2rem 0;
      }
      .confirm img {
        max-width: 100%;
        height: auto;
        display: block;
        margin: 0 auto;
      }
      .confirm p {
        line-height: 1.6;
        color: var(--ash, #7A7A78);
      }
      .confirm p strong {
        color: var(--bone, #EFE6D2);
        font-weight: 400;
      }
      .confirm a {
        color: var(--bone, #EFE6D2);
        text-decoration: underline;
        text-underline-offset: 0.25em;
      }
      [hidden] { display: none !important; }
    </style>
  </head>
  <body>
    <main class="confirm">
      <!-- Reserved view (shown when sku is valid) -->
      <section id="reserved" hidden>
        <h1>Reserved.</h1>
        <p>
          Your <strong id="product-name"></strong> entry is on the ledger.
          We'll write when there's something to say.
        </p>
        <figure>
          <img id="product-img" src="" alt="" loading="lazy" />
        </figure>
        <p>
          <a href="/">Return to STITCH AND ASH</a>
        </p>
      </section>

      <!-- Empty view (no/invalid sku) — default visible for no-JS users -->
      <section id="empty">
        <h1 class="ember">Nothing to confirm.</h1>
        <p>
          No reservation was found at this address.
          <br />
          <a href="/">Return to STITCH AND ASH</a>
        </p>
      </section>
    </main>

    <script is:inline>
      (function () {
        var names = {
          "stitch": "STITCH",
          "ash-bloom": "ASH BLOOM",
          "ampersand": "AMPERSAND"
        };
        var sku = "";
        try {
          sku = new URLSearchParams(window.location.search).get("sku") || "";
        } catch (_) { /* IE11 etc — leave empty */ }
        if (sku && Object.prototype.hasOwnProperty.call(names, sku)) {
          var productName = names[sku];
          var renderUrl = "/products/" + sku + "-front.png";
          var nameEl = document.getElementById("product-name");
          var imgEl = document.getElementById("product-img");
          if (nameEl) nameEl.textContent = productName;
          if (imgEl) {
            imgEl.src = renderUrl;
            imgEl.alt = productName + " preview";
          }
          document.title = productName + " — reserved · STITCH AND ASH";
          document.getElementById("reserved").hidden = false;
          document.getElementById("empty").hidden = true;
        }
      })();
    </script>
  </body>
</html>
