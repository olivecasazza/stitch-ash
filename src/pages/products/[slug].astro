---
/**
 * Dynamic PDP route — pre-renders all 3 SKUs at build time.
 *
 * Data strategy:
 *   1. Try getProduct(slug) from Shopify Storefront API.
 *   2. On any failure (missing env vars, API error, 404), fall back to
 *      src/data/products.ts static data and render a "preview" badge.
 *
 * Shopify env vars are not available in dev or CI before live products
 * are registered — the try/catch handles both the thrown env-var error
 * AND a null return from the API.
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import Badge from "../../components/Badge.astro";
import Button from "../../components/Button.astro";
import SizeSelector from "../../components/SizeSelector.astro";
import DetailsAccordion from "../../components/DetailsAccordion.astro";
import CartDrawer from "../../components/CartDrawer.astro";
import { PRODUCTS, type StaticProduct } from "../../data/products.ts";
import type { Product as ShopifyProduct } from "../../lib/shopify.ts";

export async function getStaticPaths() {
  return PRODUCTS.map((p) => ({
    params: { slug: p.handle },
    props: { staticProduct: p },
  }));
}

interface Props {
  staticProduct: StaticProduct;
}

const { slug } = Astro.params;
const { staticProduct } = Astro.props;

// ---------------------------------------------------------------------------
// Attempt Shopify fetch — gracefully degrade on missing env or API errors.
// ---------------------------------------------------------------------------

let shopifyProduct: ShopifyProduct | null = null;
let isPreview = false;

try {
  const { getProduct } = await import("../../lib/shopify.ts");
  shopifyProduct = await getProduct(slug);
  if (!shopifyProduct) {
    // Product not yet registered in Shopify — preview mode.
    isPreview = true;
  }
} catch {
  // Env vars missing or network error — expected in dev/CI. Fall back to static data.
  isPreview = true;
}

// ---------------------------------------------------------------------------
// Resolve display values from Shopify (if live) or static fallback.
// ---------------------------------------------------------------------------

const displayName = shopifyProduct?.title ?? staticProduct.name;
const displayDescription = shopifyProduct?.description ?? staticProduct.description;
const displayPrice = shopifyProduct?.variants[0]?.price.amount
  ? parseFloat(shopifyProduct.variants[0].price.amount).toFixed(0)
  : staticProduct.price;

// For the add-to-cart flow: use first available variant if Shopify product exists.
const variantId = shopifyProduct?.variants.find((v) => v.availableForSale)?.id ?? null;

// Size config: hoodie has sizes; lanyard/sticker are one-size.
const hasRealSizes = staticProduct.sizes.length > 1;
const sizeValues = staticProduct.sizes.map((s) => s.label);
---

<BaseLayout
  title={`${displayName} — STITCH AND ASH`}
  description={staticProduct.description}
>
  <main class="pdp wrap">
    <!-- Preview indicator — visible only when Shopify product not yet live. -->
    {isPreview && (
      <div class="pdp__preview-notice" role="status">
        <span>Preview — commerce not yet wired. No checkout available.</span>
      </div>
    )}

    <div class="pdp__layout">
      <!-- ── LEFT: Image gallery ─────────────────────────────────────────────── -->
      <div class="pdp__gallery">
        <!--
          TODO: Replace SVG placeholder with real product photography once
          available. UX_FRAMEWORK §B calls for macro embroidery detail shots
          with side lighting. Target: 1 hero image + 2-3 detail crops.
        -->
        <div class="pdp__image-placeholder" data-zoom-target>
          <svg
            viewBox="0 0 600 750"
            xmlns="http://www.w3.org/2000/svg"
            aria-label={`${displayName} — product image coming soon`}
            role="img"
            class="pdp__placeholder-svg"
          >
            <rect width="600" height="750" fill="#0B0B0B" />
            <rect
              x="1"
              y="1"
              width="598"
              height="748"
              fill="none"
              stroke="#C0C0C0"
              stroke-width="1"
              stroke-dasharray="6 6"
              opacity="0.4"
            />
            <!-- Thread-like cross-hatch to suggest embroidery texture -->
            <g stroke="#1A1A1A" stroke-width="1" opacity="0.6">
              {Array.from({ length: 20 }).map((_, i) => (
                <line
                  x1={0}
                  y1={i * 40}
                  x2={600}
                  y2={i * 40}
                />
              ))}
              {Array.from({ length: 15 }).map((_, i) => (
                <line
                  x1={i * 42}
                  y1={0}
                  x2={i * 42}
                  y2={750}
                />
              ))}
            </g>
            <text
              x="300"
              y="360"
              text-anchor="middle"
              dominant-baseline="middle"
              fill="#C0C0C0"
              font-family="Inter, system-ui, sans-serif"
              font-size="13"
              letter-spacing="0.12em"
              opacity="0.5"
            >
              {displayName.toUpperCase()}
            </text>
            <text
              x="300"
              y="385"
              text-anchor="middle"
              dominant-baseline="middle"
              fill="#C0C0C0"
              font-family="Inter, system-ui, sans-serif"
              font-size="10"
              letter-spacing="0.1em"
              opacity="0.35"
            >
              PHOTOGRAPHY COMING SOON
            </text>
          </svg>
          <!-- Zoom hint -->
          <button
            class="pdp__zoom-btn"
            aria-label="Zoom image"
            data-zoom-trigger
          >
            <svg viewBox="0 0 20 20" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <circle cx="8" cy="8" r="5.5" />
              <line x1="12.5" y1="12.5" x2="18" y2="18" />
              <line x1="8" y1="5.5" x2="8" y2="10.5" />
              <line x1="5.5" y1="8" x2="10.5" y2="8" />
            </svg>
          </button>
        </div>
      </div>

      <!-- ── RIGHT: Product info + purchase ─────────────────────────────────── -->
      <div class="pdp__info">
        <div class="pdp__badges">
          <Badge variant="made-to-order" />
          {isPreview && (
            <Badge variant="limited-run" class="pdp__preview-badge" />
          )}
        </div>

        <h1 class="pdp__name">{displayName}</h1>
        <p class="pdp__price">${displayPrice}</p>

        <p class="pdp__description">{displayDescription}</p>

        <p class="pdp__embroidery-note">{staticProduct.embroideryCopy}</p>

        <!-- Size selector — only rendered for products with real sizes (hoodie). -->
        <!-- One-size products show a plain label instead. -->
        {hasRealSizes ? (
          <div class="pdp__size-wrap">
            <SizeSelector sizes={sizeValues} selected={sizeValues[0]} />
          </div>
        ) : (
          <p class="pdp__one-size">
            <span class="pdp__one-size-label">Size</span> One size
          </p>
        )}

        <!-- Add-to-cart -->
        {variantId ? (
          <Button
            as="button"
            variant="primary"
            class="pdp__atc"
            data-variant-id={variantId}
            data-product-name={displayName}
            data-product-price={displayPrice}
          >
            Add to cart
          </Button>
        ) : (
          <Button
            as="button"
            variant="disabled"
            class="pdp__atc pdp__atc--preview"
            disabled
            aria-disabled="true"
          >
            Made to order — coming soon
          </Button>
        )}

        <!-- Details accordion -->
        <div class="pdp__accordion-wrap">
          <DetailsAccordion sections={staticProduct.details} />
        </div>
      </div>
    </div>
  </main>

  <CartDrawer />
</BaseLayout>

<style>
  .pdp {
    padding-block-start: clamp(2rem, 4vw, 3.5rem);
    padding-block-end: clamp(3rem, 8vw, 6rem);
  }

  .pdp__preview-notice {
    margin-block-end: var(--space-3);
    padding: 0.6rem 0.9rem;
    border: 1px solid color-mix(in srgb, var(--thread-gold) 35%, transparent);
    background: color-mix(in srgb, var(--thread-gold) 6%, transparent);
    color: var(--ash-silver);
    font-size: var(--text-sm);
    letter-spacing: 0.04em;
  }

  .pdp__layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 4vw, 3.5rem);
  }

  @media (min-width: 768px) {
    .pdp__layout {
      grid-template-columns: 1fr 1fr;
      align-items: start;
    }
  }

  /* ── Gallery ── */
  .pdp__gallery {
    position: sticky;
    top: var(--space-3);
  }

  .pdp__image-placeholder {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--ash-silver) 20%, transparent);
    background: var(--ink-black);
    cursor: zoom-in;
  }

  .pdp__image-placeholder[data-zoomed] {
    cursor: zoom-out;
  }

  .pdp__placeholder-svg {
    width: 100%;
    height: 100%;
    display: block;
    transition: transform var(--transition-slow);
  }

  .pdp__image-placeholder[data-zoomed] .pdp__placeholder-svg {
    transform: scale(1.6);
  }

  .pdp__zoom-btn {
    position: absolute;
    bottom: var(--space-2);
    right: var(--space-2);
    background: color-mix(in srgb, var(--ink-black) 80%, transparent);
    border: 1px solid color-mix(in srgb, var(--ash-silver) 30%, transparent);
    color: var(--ash-silver);
    width: 2rem;
    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: color var(--transition-base), border-color var(--transition-base);
    border-radius: var(--radius-none);
  }

  .pdp__zoom-btn:hover,
  .pdp__zoom-btn:focus-visible {
    color: var(--bone);
    border-color: var(--ash-silver);
    outline: 2px solid var(--thread-gold);
    outline-offset: 2px;
  }

  /* ── Info panel ── */
  .pdp__info {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .pdp__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    align-items: center;
  }

  .pdp__preview-badge {
    opacity: 0.7;
  }

  .pdp__name {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw + 0.5rem, 2.75rem);
    font-weight: 500;
    letter-spacing: 0.02em;
    line-height: 1.1;
    color: var(--bone);
  }

  .pdp__price {
    margin: 0;
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--bone);
    letter-spacing: 0.03em;
  }

  .pdp__description {
    margin: 0;
    color: var(--ash-silver);
    line-height: 1.65;
    font-size: var(--text-base);
  }

  .pdp__embroidery-note {
    margin: 0;
    font-size: var(--text-sm);
    color: color-mix(in srgb, var(--thread-gold) 70%, var(--ash-silver));
    letter-spacing: 0.04em;
    border-inline-start: 2px solid color-mix(in srgb, var(--thread-gold) 50%, transparent);
    padding-inline-start: 0.75rem;
  }

  .pdp__size-wrap {
    /* Fieldset owns its own spacing */
  }

  .pdp__one-size {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--bone);
  }

  .pdp__one-size-label {
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ash-silver);
    margin-inline-end: 0.5ch;
  }

  .pdp__atc {
    width: 100%;
    justify-content: center;
  }

  /* Override disabled button to use Thread Gold border/text for the preview CTA. */
  .pdp__atc--preview {
    border-color: color-mix(in srgb, var(--thread-gold) 50%, transparent) !important;
    color: color-mix(in srgb, var(--thread-gold) 70%, var(--ash-silver)) !important;
    opacity: 1 !important;
  }

  .pdp__accordion-wrap {
    margin-block-start: var(--space-1);
  }
</style>

<script>
  // ── Zoom toggle (click/tap — not hover-only, per UX_FRAMEWORK §B) ──
  const zoomTarget = document.querySelector<HTMLElement>("[data-zoom-target]");
  if (zoomTarget) {
    zoomTarget.addEventListener("click", () => {
      if (zoomTarget.hasAttribute("data-zoomed")) {
        zoomTarget.removeAttribute("data-zoomed");
        zoomTarget.setAttribute("aria-label", "Zoom image");
      } else {
        zoomTarget.setAttribute("data-zoomed", "");
        zoomTarget.setAttribute("aria-label", "Collapse image");
      }
    });
  }

  // ── Add-to-cart fetch ──────────────────────────────────────────────────────
  // Only wired when a real variantId is present in data-variant-id.
  const atcBtn = document.querySelector<HTMLButtonElement>("[data-variant-id]");
  if (atcBtn) {
    atcBtn.addEventListener("click", async () => {
      const variantId = atcBtn.dataset["variantId"];
      const productName = atcBtn.dataset["productName"] ?? "Product";
      const productPrice = parseFloat(atcBtn.dataset["productPrice"] ?? "0");

      if (!variantId) return;

      // Optimistic: add to local cart for drawer display, then get checkout URL.
      const selectedSize =
        (document.querySelector<HTMLInputElement>(".size-selector__input:checked")?.value) ??
        "One size";

      window.CartDrawer?.addItem({
        id: variantId,
        name: productName,
        size: selectedSize,
        price: Math.round(productPrice * 100),
        qty: 1,
      });

      window.CartDrawer?.open();

      try {
        const res = await fetch("/api/checkout", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            items: [{ variantId, quantity: 1 }],
          }),
        });

        if (!res.ok) return;
        const { checkoutUrl } = await res.json();
        if (checkoutUrl) window.location.href = checkoutUrl;
      } catch {
        // Silent failure — cart drawer is already open with the item.
      }
    });
  }
</script>
