---
import '../styles/global.css';

const shopifyStoreDomain = import.meta.env.PUBLIC_SHOPIFY_STORE_DOMAIN;
const shopifyBaseUrl = shopifyStoreDomain ? `https://${shopifyStoreDomain.replace(/^https?:\/\//, '')}` : null;

const products = [
  {
    sku: 'SKU-001',
    name: 'MARK TEE',
    price: '$68',
    image: '/assets/sku1-mark-on-tee-mock.svg',
    route: '/products/mark-tee',
    summary: 'Heavyweight black tee with a restrained left-chest embroidered sigil.',
    badges: ['240gsm cotton', 'left chest', 'black thread'],
  },
  {
    sku: 'SKU-002',
    name: 'VOW HOODIE',
    price: '$148',
    image: '/assets/sku2-vow-on-hoodie-mock.svg',
    route: '/products/vow-hoodie',
    summary: 'Dense fleece hoodie carrying the large back vow embroidery in tonal thread.',
    badges: ['480gsm fleece', 'back piece', 'tonal stitch'],
  },
  {
    sku: 'SKU-003',
    name: 'EMBER CAP',
    price: '$54',
    image: '/assets/sku3-ember-on-cap-mock.svg',
    route: '/products/ember-cap',
    summary: 'Low-profile black cap with copper ember mark stitched at front crown.',
    badges: ['6 panel', 'copper thread', 'adjustable'],
  },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="STITCH & ASH preview storefront for black apparel with exclusively embroidered designs."
    />
    <title>STITCH & ASH — Embroidered black apparel</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <nav class="container nav" aria-label="Primary navigation">
          <a class="brand" href="#top" aria-label="STITCH AND ASH home">
            <span>STITCH & ASH</span>
            <span>Thread only</span>
          </a>
          <div class="nav-links" aria-label="Store sections">
            <a href="/#drop">Drop</a>
            <a href="/#craft">Craft</a>
            {shopifyBaseUrl ? <a href={shopifyBaseUrl}>Shop</a> : <a href="/#reserve">Reserve</a>}
          </div>
          <a class="btn btn-secondary" href={shopifyBaseUrl ? shopifyBaseUrl : "/#reserve"}>{shopifyBaseUrl ? 'Go to Shopify' : 'Join waitlist'}</a>
        </nav>
      </header>

      <main id="top">
        <section class="hero">
          <div class="container hero-grid">
            <div class="hero-copy">
              <span class="kicker">Preview drop 001</span>
              <h1 class="display">Black apparel. Embroidery only.</h1>
              <p class="body-lg">
                STITCH & ASH makes quiet, heavy black essentials carrying tactile threadwork instead of prints,
                plastic transfers, or foam. The first capsule is built around three pilot pieces for the preview launch.
              </p>
              <div class="hero-actions">
                <a class="btn btn-primary" href="#drop">View the capsule</a>
                <a class="btn" href="#craft">See craft details</a>
              </div>
              <div class="hero-proof" aria-label="Craft proof points">
                <div class="proof-pill"><strong>0</strong><span class="muted">printed graphics</span></div>
                <div class="proof-pill"><strong>3</strong><span class="muted">pilot silhouettes</span></div>
                <div class="proof-pill"><strong>100%</strong><span class="muted">thread-based marks</span></div>
              </div>
            </div>
            <div class="hero-media" aria-label="Vow hoodie preview">
              <div class="card">
                <img src="/assets/sku2-vow-on-hoodie-mock.svg" alt="Black Vow Hoodie with embroidered back mark" />
              </div>
            </div>
          </div>
        </section>

        <section class="section" id="drop">
          <div class="container">
            <div class="section-head">
              <div>
                <span class="kicker">Pilot capsule</span>
                <h2 class="heading-xl">Three pieces, one rule: stitch it.</h2>
              </div>
              <p class="body-lg">
                Each product card uses the current design handoff assets and a storefront-ready component structure for
                home, product, cart, and reservation flows to build on.
              </p>
            </div>
            <div class="product-grid">
              {products.map((product) => (
                <article class="card product-card">
                  <a class="product-card__media" href={product.route} aria-label={`Open ${product.name}`}>
                    <img src={product.image} alt={`${product.name} embroidered mockup`} />
                  </a>
                  <div class="product-card__body">
                    <div class="product-card__meta">
                      <span>{product.sku}</span>
                      <span>{product.price}</span>
                    </div>
                    <h3>{product.name}</h3>
                    <p class="muted">{product.summary}</p>
                    <div class="badges" aria-label={`${product.name} details`}>
                      {product.badges.map((badge) => <span class="badge">{badge}</span>)}
                    </div>
                    <div class="product-actions">
                      <a class="btn btn-primary" href={shopifyBaseUrl ? `${shopifyBaseUrl}/products/${product.sku.toLowerCase()}` : `${product.route}#reserve`}>{shopifyBaseUrl ? 'Buy on Shopify' : 'Reserve'}</a>
                      <a class="btn" href={product.route}>Details</a>
                    </div>
                  </div>
                </article>
              ))}
            </div>
          </div>
        </section>

        <section class="section" id="craft">
          <div class="container split">
            <div class="panel">
              <span class="kicker">Design-token layer</span>
              <h2 class="heading-lg">A base shell for the full Astro storefront.</h2>
              <p class="body-lg">
                The layout introduces shared color, spacing, radius, type, button, form, card, nav, footer, and product-card
                primitives in CSS custom properties so the remaining commerce routes can stay visually consistent.
              </p>
              <ul class="spec-list">
                <li><strong>Palette</strong><span class="muted">ash black, warm cream, tarnished thread gold, ember copper.</span></li>
                <li><strong>Typography</strong><span class="muted">editorial display serif paired with compact UI sans.</span></li>
                <li><strong>Components</strong><span class="muted">sticky nav, shell, cards, badges, buttons, fields, proof panels.</span></li>
              </ul>
            </div>
            <div class="panel">
              <span class="kicker">Embroidery spec</span>
              <h2 class="heading-lg">No print. No foam. No shortcuts.</h2>
              <p class="body-lg">
                Product storytelling is framed around tactile, digitized embroidery: restrained chest marks, tonal back
                pieces, and copper accent thread that still reads premium on black blanks.
              </p>
              <ul class="spec-list">
                <li><strong>Thread</strong><span class="muted">rayon/poly blend selected per placement and contrast.</span></li>
                <li><strong>Placement</strong><span class="muted">left chest, back panel, and cap crown mapped to pilot SKUs.</span></li>
                <li><strong>Care</strong><span class="muted">cold wash, inside out, air dry to preserve thread sheen.</span></li>
              </ul>
            </div>
          </div>
        </section>

        <section class="section" id="reserve">
          <div class="container">
            <div class="panel">
              <span class="kicker">Preview reservation</span>
              <h2 class="heading-xl">Hold your place before checkout opens.</h2>
              <p class="body-lg">
                {shopifyBaseUrl
                  ? 'Checkout is handled by Shopify so orders, payments, and inventory stay in the Shopify operations account.'
                  : 'This preview uses reservation language until production checkout is connected. The form captures launch interest and preferred pilot piece without implying live payment processing.'}
              </p>
              <form class="waitlist-form" action="/thanks" method="get">
                <div class="form-row">
                  <input class="field" type="email" name="email" placeholder="email@example.com" aria-label="Email address" required />
                  <button class="btn btn-primary" type="submit">Join waitlist</button>
                </div>
                <select class="field" name="piece" aria-label="Preferred pilot piece">
                  {products.map((product) => <option value={product.sku}>{product.name} — {product.price}</option>)}
                </select>
              </form>
            </div>
          </div>
        </section>
      </main>

      <footer class="site-footer">
        <div class="container footer-grid">
          <a class="brand" href="#top"><span>STITCH & ASH</span><span>Preview storefront</span></a>
          <p>© 2026 STITCH & ASH. Exclusively embroidered black apparel.</p>
        </div>
      </footer>
    </div>
  </body>
</html>
