---
import BaseLayout from '../layouts/BaseLayout.astro';
import { products } from '../data/products';
---
<BaseLayout>
  <main>
    <section class="hero section container">
      <div class="hero-copy">
        <p class="kicker">exclusively embroidered black apparel</p>
        <h1 class="display-title"><span class="brand-type">Stitch &amp; Ash</span></h1>
        <p class="copy">A first drop of black apparel built around tactile embroidery that changes with each garment structure.</p>
        <div class="actions">
          <a class="button primary" href="#products">Shop the drop</a>
          <a class="button secondary" href="#craft">Read the craft notes</a>
        </div>
      </div>
      <div class="hero-card product-image-frame">
        <img src={products[0].image} alt={products[0].alt} />
      </div>
    </section>

    <section id="craft" class="craft section-tight container">
      <p class="kicker">brand system</p>
      <h2 class="section-title">Thread, ash, and restrained contrast.</h2>
      <p class="copy">Bone, ember, and ash threadwork now defines the pilot line: structural embroidery for a hoodie, a draped tunic, and a canvas work jacket rather than logo-only merch.</p>
    </section>

    <section id="products" class="products section-tight container">
      {products.map((product) => (
        <article class="product-card">
          <a href={`/products/${product.slug}/`} aria-label={`View ${product.name}`}>
            <div class="product-image-frame">
              <img src={product.image} alt={product.alt} />
            </div>
            <div class="product-copy">
              <p class="kicker">{product.type}</p>
              <h2 class="card-title">{product.name}</h2>
              <p class="small-copy">{product.accent}</p>
              <p class="price">{product.price}</p>
            </div>
          </a>
        </article>
      ))}
    </section>
  </main>
</BaseLayout>

<style>
  main { padding-bottom: var(--section-block-tight); }
  .hero { display: grid; grid-template-columns: minmax(0, 1.02fr) minmax(17.5rem, 0.98fr); gap: var(--space-5); align-items: center; }
  .hero-copy { display: grid; gap: var(--space-3); }
  .hero-copy .copy { max-width: 42rem; font-size: var(--text-md); }
  .actions { display: flex; flex-wrap: wrap; gap: var(--space-2); margin-top: var(--space-2); }
  .button { border: 1px solid var(--border-muted); border-radius: 999px; font-family: var(--font-heading); font-size: var(--text-sm); font-weight: 800; letter-spacing: 0.08em; padding: 0.9rem 1.25rem; text-transform: uppercase; }
  .button.primary { background: var(--color-ash); color: var(--color-ink); }
  .button.secondary { background: rgba(242, 238, 230, 0.04); color: var(--color-ash); }
  .hero-card, .product-card, .craft { background: var(--surface-card); border: 1px solid var(--border-muted); border-radius: var(--radius-panel); box-shadow: 0 1.5rem 5rem rgba(0,0,0,0.36); overflow: hidden; }
  .hero-card { padding: var(--space-4); }
  .craft { padding: var(--space-5); }
  .craft .copy { max-width: 55rem; }
  .products { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: var(--space-3); }

  .product-copy { display: grid; gap: 0.45rem; padding: var(--space-3); }
  .price { color: var(--color-ash); font-family: var(--font-heading); font-size: var(--text-md); font-weight: 800; margin: 0; }
  @media (max-width: 820px) { .hero, .products { grid-template-columns: 1fr; } .hero { padding-top: var(--space-6); } }
</style>
