---
const isAdminPreview = Astro.url.searchParams.get("admin") === "1";
---

<!doctype html>
<html lang="en" data-admin-preview={isAdminPreview ? "true" : "false"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="STITCH AND ASH — embroidered apparel. Gothic precision." />
    <title>STITCH AND ASH</title>
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <main>
      <h1>STITCH AND ASH</h1>
      <p>Coming soon.</p>
      <p><a href="/products/stitch/">Preview the STITCH wordmark tee</a></p>
      <p><a href="/ops-platform/">Operations platform recommendation</a></p>
    </main>

    <button class="bug-report-trigger" type="button" data-bug-trigger>
      Report bug
    </button>

    <dialog class="bug-report-dialog" data-bug-dialog>
      <form class="bug-report-form" method="dialog" data-bug-form>
        <div class="bug-report-header">
          <div>
            <p class="eyebrow">Site feedback</p>
            <h2>Report a bug</h2>
          </div>
          <button class="icon-button" type="button" aria-label="Close bug report" data-bug-close>×</button>
        </div>

        <p class="bug-report-copy" data-user-copy>
          Tell us what broke. This goes to the human Stitch & Ash admin queue, not the engineering backlog.
        </p>
        <p class="bug-report-copy admin-only" data-admin-copy>
          Admin mode is active. Submitting creates a Paperclip issue for the software development team.
        </p>

        <label>
          What happened?
          <textarea name="description" rows="5" required placeholder="Expected checkout to open, but the button did nothing..."></textarea>
        </label>

        <label>
          Contact email (optional)
          <input name="email" type="email" autocomplete="email" placeholder="you@example.com" />
        </label>

        <label class="admin-only">
          Engineering severity
          <select name="severity">
            <option value="low">Low — polish / copy / layout</option>
            <option value="medium" selected>Medium — blocks a path but workaround exists</option>
            <option value="high">High — checkout, money, fulfillment, or admin path broken</option>
            <option value="urgent">Urgent — production outage or data/security risk</option>
          </select>
        </label>

        <label class="admin-only checkbox-row">
          <input name="includeDiagnostics" type="checkbox" checked />
          Attach route, viewport, user agent, and admin diagnostics
        </label>

        <input type="hidden" name="route" data-bug-route />
        <input type="hidden" name="adminMode" data-bug-admin-mode />
        <input type="hidden" name="diagnostics" data-bug-diagnostics />

        <div class="bug-report-actions">
          <output class="bug-report-status" data-bug-status></output>
          <button class="button secondary" type="button" data-bug-close>Cancel</button>
          <button class="button" type="submit">Submit report</button>
        </div>
      </form>
    </dialog>

    <script>
      const adminFlag = new URLSearchParams(window.location.search).get("admin") === "1";
      const adminStorageKey = "stitchAshAdminMode";
      if (adminFlag) localStorage.setItem(adminStorageKey, "true");
      const adminMode = localStorage.getItem(adminStorageKey) === "true";
      document.documentElement.dataset.adminPreview = adminMode ? "true" : "false";

      const dialog = document.querySelector("[data-bug-dialog]");
      const form = document.querySelector("[data-bug-form]");
      const status = document.querySelector("[data-bug-status]");
      const routeInput = document.querySelector("[data-bug-route]");
      const adminModeInput = document.querySelector("[data-bug-admin-mode]");
      const diagnosticsInput = document.querySelector("[data-bug-diagnostics]");

      const diagnostics = () => ({
        href: window.location.href,
        path: window.location.pathname,
        viewport: `${window.innerWidth}x${window.innerHeight}`,
        userAgent: navigator.userAgent,
        referrer: document.referrer || null,
        adminMode,
        timestamp: new Date().toISOString(),
      });

      document.querySelectorAll("[data-bug-trigger]").forEach((button) => {
        button.addEventListener("click", () => {
          routeInput.value = window.location.pathname;
          adminModeInput.value = adminMode ? "true" : "false";
          diagnosticsInput.value = JSON.stringify(diagnostics());
          status.textContent = "";
          dialog.showModal();
        });
      });

      document.querySelectorAll("[data-bug-close]").forEach((button) => {
        button.addEventListener("click", () => dialog.close());
      });

      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        status.textContent = "Sending...";
        const submitButton = form.querySelector('button[type="submit"]');
        submitButton.disabled = true;

        try {
          const payload = Object.fromEntries(new FormData(form).entries());
          payload.adminMode = adminMode;
          payload.diagnostics = diagnostics();

          const response = await fetch("/api/bug-report", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload),
          });
          const result = await response.json();
          if (!response.ok) throw new Error(result.error || "Unable to submit report");

          status.textContent = adminMode
            ? `Created Paperclip issue ${result.identifier || "for software development"}.`
            : "Sent to the Stitch & Ash admin queue.";
          form.reset();
          setTimeout(() => dialog.close(), 1200);
        } catch (error) {
          status.textContent = error instanceof Error ? error.message : "Unable to submit report";
        } finally {
          submitButton.disabled = false;
        }
      });
    </script>
  </body>
</html>
