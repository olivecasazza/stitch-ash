---
// Button — primary / secondary / tertiary / disabled variants.
// Renders as <a> or <button> depending on `as` prop.
// 2px radius or no radius per UX_FRAMEWORK §2. Focus ring in Thread Gold.
export interface Props {
  variant?: "primary" | "secondary" | "tertiary" | "disabled";
  as?: "a" | "button";
  href?: string;
  type?: "button" | "submit" | "reset";
  class?: string;
  [key: string]: unknown;
}

const {
  variant = "primary",
  as: Tag = "button",
  href,
  type = "button",
  class: className,
  ...rest
} = Astro.props;

const isDisabled = variant === "disabled";
const classes = ["btn", `btn--${variant}`, className].filter(Boolean).join(" ");
---
{
  Tag === "a" ? (
    <a
      href={href}
      class={classes}
      aria-disabled={isDisabled ? "true" : undefined}
      {...rest}
    >
      <slot />
    </a>
  ) : (
    <button
      type={type}
      class={classes}
      disabled={isDisabled}
      {...rest}
    >
      <slot />
    </button>
  )
}

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4em;
    font: inherit;
    font-weight: 600;
    font-size: 0.86rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.7rem 1.4rem;
    border-radius: var(--radius-tight);
    border: 1px solid transparent;
    cursor: pointer;
    transition:
      background var(--transition-base),
      color var(--transition-base),
      border-color var(--transition-base);
  }

  .btn:focus-visible {
    outline: 2px solid var(--thread-gold);
    outline-offset: 2px;
  }

  /* Primary — black fill on light, white fill on dark (dark is default context) */
  .btn--primary {
    background: var(--bone);
    color: var(--ink-black);
    border-color: var(--bone);
  }
  .btn--primary:hover:not(:disabled):not([aria-disabled="true"]) {
    background: var(--crisp-white);
    border-color: var(--crisp-white);
  }

  /* Secondary — outline */
  .btn--secondary {
    background: transparent;
    color: var(--bone);
    border-color: var(--bone);
  }
  .btn--secondary:hover:not(:disabled):not([aria-disabled="true"]) {
    background: color-mix(in srgb, var(--bone) 10%, transparent);
  }

  /* Tertiary — text link with underline on hover */
  .btn--tertiary {
    background: transparent;
    color: var(--bone);
    border-color: transparent;
    padding-inline: 0;
    font-weight: 400;
    letter-spacing: 0.03em;
    text-transform: none;
  }
  .btn--tertiary:hover:not(:disabled):not([aria-disabled="true"]) {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* Disabled — Ash Silver border/text, no fill */
  .btn--disabled,
  .btn:disabled {
    background: transparent;
    color: var(--ash-silver);
    border-color: var(--ash-silver);
    cursor: not-allowed;
    opacity: 0.6;
  }
</style>
