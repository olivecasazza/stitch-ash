---
// Header — sticky-but-subtle nav with wordmark SVG and primary nav links.
// Cart indicator is numeric and quiet per UX_FRAMEWORK §2.
---
<header class="site-header">
  <a href="/" aria-label="STITCH AND ASH home">
    <svg class="mark" viewBox="0 0 220 32" role="img" aria-label="STITCH AND ASH">
      <text
        x="0"
        y="24"
        font-family='"UnifrakturMaguntia", "Old English Text MT", "Cambria", serif'
        font-size="26"
        letter-spacing="1.5"
        font-weight="400"
      >STITCH &amp; ASH</text>
    </svg>
  </a>
  <nav aria-label="Primary">
    <a href="/products/stitch">Shop</a>
    <a href="/#statement">Story</a>
    <a href="#">Account</a>
    <a href="#" class="cart-link" aria-label="Cart (0 items)">
      Cart&nbsp;<span class="cart-count" aria-hidden="true">0</span>
    </a>
  </nav>
</header>

<style>
  .cart-link {
    display: inline-flex;
    align-items: baseline;
    gap: 0.25em;
  }
  .cart-count {
    font-size: 0.72rem;
    letter-spacing: 0;
    text-transform: none;
    color: var(--ash-silver);
    min-width: 1ch;
  }
</style>
